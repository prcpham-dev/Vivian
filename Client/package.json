{
  "name": "vivian",
  "displayName": "Vivian",
  "description": "Code analysis tool designed to visualize the codebase as an interactive graph.",
  "version": "1.0",
  "publisher": "prcpham",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vivian.openGraph",
        "title": "Vivian: Open Code Graph",
        "icon": "$(telescope)"
      },
      {
        "command": "vivian.openVulnManager",
        "title": "Vivian: Open Vulnerability Manager"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "vivian.openGraph",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Vivian",
      "properties": {
        "vivian.sidecarPort": {
          "type": "number",
          "default": 8765,
          "description": "Port for the Vivian Python sidecar server"
        },
        "vivian.autoStartSidecar": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the Python sidecar when opening the graph"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "node esbuild.js --production"
  },
  "dependencies": {
    "lucide-react": "^0.300.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}