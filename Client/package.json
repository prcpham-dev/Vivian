{
  "name": "vivian",
  "displayName": "Vivian — Code Graph",
  "description": "Interactive D3 force-directed code relationship graph with AI analysis",
  "version": "0.1.0",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Visualization", "Other"],
  "activationEvents": ["onCommand:vivian.openGraph"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vivian.openGraph",
        "title": "Vivian: Open Code Graph"
      }
    ],
    "configuration": {
      "title": "Vivian",
      "properties": {
        "vivian.sidecarPort": {
          "type": "number",
          "default": 8765,
          "description": "Port for the Vivian Python sidecar server"
        },
        "vivian.autoStartSidecar": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the Python sidecar when opening the graph"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "node esbuild.js --production"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
